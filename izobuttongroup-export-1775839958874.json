                "data": {
                  "value": "{{input.buttonGroupData}}"
                },
                "code": {
                  "value": "import React, { useEffect, useState } from 'https://cdn.jsdelivr.net/npm/react@18.2.0/+esm';\nimport ReactDOM from 'https://cdn.jsdelivr.net/npm/react-dom@18.2.0/client/+esm';\n\nfunction ShadcnButtonGroup(props) {\n  const [isLoaded, setIsLoaded] = useState(false);\n\n  useEffect(() => {\n    const styleId = 'tooljet-segmented-final-pixel-perfect';\n    if (!document.getElementById(styleId)) {\n      const style = document.createElement('style');\n      style.id = styleId;\n      style.innerHTML = `\n        html, body, #root {\n          margin: 0; padding: 0; height: 100%;\n          background: transparent !important;\n          font-family: \"Inter\", sans-serif !important;\n          display: flex; align-items: center;\n        }\n\n        .segmented-container {\n          display: inline-flex;\n          background-color: #ffffff;\n          border: 1px solid #e0e2e3;\n          border-radius: 8px;\n          overflow: hidden;\n          height: 46px;\n        }\n\n        .segment-item {\n          appearance: none;\n          background: transparent;\n          border: none;\n          color: #535862;\n          cursor: pointer;\n          font-family: \"Inter\", sans-serif;\n          font-size: 15px;\n          font-weight: 500;\n          padding: 0 24px;\n          display: flex;\n          align-items: center;\n          justify-content: center;\n          transition: all 0.2s ease;\n          position: relative;\n          white-space: nowrap;\n        }\n\n        .segment-item:not(:last-child)::after {\n          content: '';\n          position: absolute;\n          right: 0;\n          top: 0;\n          bottom: 0;\n          width: 1px;\n          background-color: #e0e2e3;\n        }\n\n        .segment-item.active {\n          background-color: #DAEFFA;\n          color: #1d7eb9;\n        }\n\n        .segment-item.active::after {\n          display: none !important;\n        }\n\n        .segment-item:has(+ .active)::after {\n          display: none !important;\n        }\n\n        .segment-item:hover:not(.active) {\n          background-color: #f8fafc;\n        }\n\n        .segment-item:focus {\n          outline: none;\n        }\n      `;\n      document.head.appendChild(style);\n    }\n    setIsLoaded(true);\n  }, []);\n\n  const options = props.data?.options || ['Monthly', 'Quarterly'];\n\n  // ✅ ONLY use internal data here\n  const selected = props.data?.selected || options[0];\n\n  if (!isLoaded) return null;\n\n  // ✅ ONLY update internal state\n  const handleSelect = (val) => {\n    props.updateData?.({ selected: val });\n  };\n\n  return React.createElement(\n    'div',\n    { className: 'segmented-container' },\n    options.map((option) =>\n      React.createElement(\n        'button',\n        {\n          key: option,\n          type: 'button',\n          className: `segment-item ${selected === option ? 'active' : ''}`,\n          onClick: () => handleSelect(option),\n        },\n        option\n      )\n    )\n  );\n}\n\nconst ConnectedComponent = Tooljet.connectComponent(ShadcnButtonGroup);\n\nif (!window.tooljetRoot) {\n  window.tooljetRoot = ReactDOM.createRoot(document.body);\n}\nwindow.tooljetRoot.render(React.createElement(ConnectedComponent));",

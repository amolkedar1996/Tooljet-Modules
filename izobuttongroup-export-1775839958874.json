              "name": "button-group-container",
              "type": "CustomComponent",
              "pageId": "d9ec45da-2418-4540-8d8c-667676bba4e0",
              "parent": "c1783894-3944-4d77-9388-ca2967c42eff",
              "properties": {
                "visible": {

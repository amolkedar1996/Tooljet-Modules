                "data": {
                  "value": "{{input.badgeData}}"
                },
                "code": {
                  "value": "import React, { useEffect, useState } from 'https://cdn.jsdelivr.net/npm/react@18.2.0/+esm';\nimport ReactDOM from 'https://cdn.jsdelivr.net/npm/react-dom@18.2.0/client/+esm';\n\nfunction IZOBadgeRow(props) {\n  const [isLoaded, setIsLoaded] = useState(false);\n\n  useEffect(() => {\n    const styleId = 'izo-badge-native-fixed';\n    if (!document.getElementById(styleId)) {\n      const style = document.createElement('style');\n      style.id = styleId;\n      style.innerHTML = `\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');\n        \n        html, body, #root {\n          margin: 0; padding: 0; height: 100%;\n          background: transparent !important;\n          font-family: 'Inter', sans-serif !important;\n          display: flex; align-items: center;\n          overflow: hidden;\n        }\n\n        .izo-row {\n          display: flex;\n          align-items: center;\n          gap: 8px;\n          margin-left: 8px;\n          min-width: 0; /* Important for flex child truncation */\n        }\n\n        .izo-badge {\n          display: inline-flex;\n          align-items: center;\n          justify-content: center;\n          background-color: #DAEFFA;\n          color: #1D7EB9;\n          border-radius: 9999px;\n          padding: 6px 16px;\n          font-size: 14px;\n          font-weight: 600;\n          white-space: nowrap;\n          border: none;\n          flex-shrink: 0; /* Keeps the pill shape intact */\n        }\n\n        /* --- THE TRUNCATION FIX --- */\n        .izo-truncate {\n          display: inline-block;\n          max-width: 180px;      /* Ellipsis triggers exactly at 180px */\n          overflow: hidden;\n          text-overflow: ellipsis;\n          white-space: nowrap;\n          vertical-align: middle;\n        }\n      `;\n      document.head.appendChild(style);\n    }\n    setIsLoaded(true);\n  }, []);\n\n  const items = props.data?.items || [];\n  if (!isLoaded || items.length === 0) return null;\n\n  const firstItem = items[0];\n  const remaining = items.slice(1);\n  const count = remaining.length;\n  const remainingText = remaining.join(', ');\n\n  return React.createElement(\n    'div',\n    { className: 'izo-row' },\n    \n    // Primary Badge\n    React.createElement(\n      'div',\n      { \n        className: 'izo-badge', \n        title: firstItem // Native Overlay Tooltip\n      },\n      // Inner span ensures text-overflow works correctly\n      React.createElement('span', { className: 'izo-truncate' }, firstItem)\n    ),\n\n    // Count Badge (+N)\n    count > 0 && React.createElement(\n      'div', \n      { \n        className: 'izo-badge',\n        title: remainingText // Native Overlay Tooltip\n      }, \n      `+${count}`\n    )\n  );\n}\n\nconst ConnectedComponent = Tooljet.connectComponent(IZOBadgeRow);\n\nif (!window.tooljetRoot) {\n  window.tooljetRoot = ReactDOM.createRoot(document.body);\n}\nwindow.tooljetRoot.render(React.createElement(ConnectedComponent));",
